{
  "name": "web-solvro-auth",
  "version": "1.0.0",
  "description": "Starter for Keycloakify 11",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git://github.com/codegouvfr/keycloakify-starter.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build-keycloak-theme": "npm run build && keycloakify build",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "lint": "eslint . --max-warnings=0",
    "prepare": "husky || true",
    "start": "keycloakify start-keycloak",
    "storybook": "storybook dev -p 6006",
    "types:check": "tsc --noEmit"
  },
  "lint-staged": {
    "*": "prettier -w --ignore-unknown"
  },
  "prettier": "@solvro/config/prettier",
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.9",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keycloakify": "^11.15.11",
    "knip": "^6.27.0",
    "lucide-react": "^1.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@eslint/js": "^9.39.5",
    "@solvro/config": "^2.3.4",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.1.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^0.12.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "postcss": "^8.5.22",
    "prettier": "3.9.5",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "volta": {
    "node": "22.23.1",
    "npm": "11.18.0"
  },
  "allowScripts": {
    "esbuild": false
  }
}
